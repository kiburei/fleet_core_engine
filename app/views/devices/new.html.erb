<% content_for :header do %>
  <% header_title = @vehicle ? "#{@vehicle.registration_number} — Assign GPS Device" : "Register GPS Device" %>
  <%= render "rui/shared/admin/nav", { header_title: header_title } do %>
    <div class="flex gap-3 mb-4">
      <% if @vehicle %>
        <%= link_to "← Back to Vehicle", vehicle_path(@vehicle), class: "btn btn-secondary" %>
      <% else %>
        <%= link_to "← Back to Devices", devices_path, class: "btn btn-secondary" %>
      <% end %>
    </div>
  <% end %>
<% end %>

<div class="pt-4 px-4 sm:px-6 lg:px-8 max-w-xl mx-auto space-y-6">

  <%# ── Traccar error banner ────────────────────────────────────────────── %>
  <% if @traccar_error.present? %>
    <div class="p-3 bg-yellow-50 border border-yellow-200 rounded text-sm text-yellow-800">
      Could not reach Traccar: <%= @traccar_error %> — enter device details manually below.
    </div>
  <% end %>

  <%= form_with model: @device, local: true, class: "bg-white dark:bg-slate-800 p-6 rounded-lg shadow space-y-5" do |f| %>

    <h1 class="text-xl font-bold text-slate-900 dark:text-white">Assign GPS Device</h1>

    <%# ── Traccar device picker ──────────────────────────────────────────── %>
    <% if @available_traccar_devices.any? %>
      <div class="p-4 bg-blue-50 border border-blue-200 rounded-md space-y-3">
        <p class="text-sm font-semibold text-blue-800">Select from Traccar</p>
        <p class="text-xs text-blue-700">
          Picking a device auto-fills the fields below and links it to Traccar for live tracking.
        </p>

        <select id="traccar-picker" class="input w-full text-slate-900">
          <option value="">— Choose a Traccar device —</option>
          <% @available_traccar_devices.each do |td| %>
            <option
              value="<%= td['id'] %>"
              data-name="<%= h td['name'] %>"
              data-unique-id="<%= h td['uniqueId'] %>"
              data-status="<%= h td['status'] %>">
              #<%= td['id'] %> — <%= td['name'] %> (<%= td['uniqueId'] %>)
            </option>
          <% end %>
        </select>
      </div>
    <% end %>

    <%# Hidden traccar_id, populated by JS when a Traccar device is picked %>
    <%= f.hidden_field :traccar_id, id: "device_traccar_id" %>

    <%# ── Device fields ───────────────────────────────────────────────────── %>
    <div>
      <%= f.label :name, "Device Name", class: "text-sm font-medium text-slate-700 dark:text-slate-300" %>
      <%= f.text_field :name, id: "device_name",
            placeholder: "e.g. Tracker 01",
            class: "input w-full mt-1" %>
    </div>

    <div>
      <%= f.label :terminal_id, "Terminal ID (IMEI)", class: "text-sm font-medium text-slate-700 dark:text-slate-300" %>
      <%= f.text_field :terminal_id, id: "device_terminal_id",
            placeholder: "e.g. 123456789012345",
            class: "input w-full mt-1" %>
      <p class="text-xs text-slate-500 mt-1">Auto-filled from Traccar unique ID when a device is selected above.</p>
    </div>

    <div>
      <%= f.label :sim_number, "SIM Phone Number", class: "text-sm font-medium text-slate-700 dark:text-slate-300" %>
      <%= f.text_field :sim_number, id: "device_sim_number",
            placeholder: "e.g. +254712345678",
            class: "input w-full mt-1" %>
    </div>

    <% if @vehicle %>
      <%= f.hidden_field :vehicle_id %>
    <% else %>
      <div>
        <%= f.label :vehicle_id, "Assign to Vehicle", class: "text-sm font-medium text-slate-700 dark:text-slate-300" %>
        <%= f.collection_select :vehicle_id, Vehicle.all, :id, :registration_number,
              { prompt: "Select vehicle" },
              class: "input w-full mt-1" %>
      </div>
    <% end %>

    <div>
      <%= f.label :status, "Status", class: "text-sm font-medium text-slate-700 dark:text-slate-300" %>
      <%= f.select :status, [["Active", "active"], ["Inactive", "inactive"]],
            { selected: "active" },
            class: "input w-full mt-1" %>
    </div>

    <div class="pt-2">
      <%= f.submit "Save Device", class: "btn btn-primary w-full" %>
    </div>

  <% end %>

</div>

<script>
  (function () {
    function init() {
      const picker     = document.getElementById("traccar-picker");
      const traccarId  = document.getElementById("device_traccar_id");
      const nameField  = document.getElementById("device_name");
      const imeiField  = document.getElementById("device_terminal_id");

      if (!picker) return;

      picker.addEventListener("change", function () {
        const opt = picker.options[picker.selectedIndex];

        if (opt.value === "") {
          traccarId.value = "";
          return;
        }

        traccarId.value = opt.value;

        // Only auto-fill if the field is currently empty
        if (!nameField.value) nameField.value = opt.dataset.name || "";
        if (!imeiField.value) imeiField.value = opt.dataset.uniqueId || "";
      });
    }

    document.addEventListener("turbo:load", init);
    if (document.readyState !== "loading") init();
  })();
</script>
