<div class="max-w-5xl mx-auto bg-white dark:bg-slate-800 p-6 rounded-lg shadow space-y-8">

  <!-- Vehicle Header -->
  <div class="flex justify-between items-start gap-6 flex-wrap sm:flex-nowrap">
  <!-- Left: Image + Title -->
  <div class="flex items-center gap-6">
    <div class="w-24 h-24 rounded-full overflow-hidden bg-slate-200 flex items-center justify-center">
      <% if vehicle.logo.attached? %>
        <%= image_tag url_for(vehicle.logo), alt: vehicle.registration_number,
            class: "rounded-full sm:size-10 size-14 object-cover bg-slate-100" %>
      <% else %>
        <% reg_number = vehicle.registration_number.to_s %>
        <div class="flex flex-col items-center justify-center bg-white text-black border border-gray-300 rounded sm:w-15 sm:h-15 w-14 h-14 shadow-inner leading-tight text-center tracking-wider"
            style="font-family: 'Courier New', Courier, monospace; font-weight: bold;">
          <span class="text-xs-5"><%= reg_number[0, 3] %></span>
          <span class="text-xs-5"><%= reg_number[3..] %></span>
        </div>
      <% end %>
    </div>
    <div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white"><%= vehicle.registration_number %></h1>
      <p class="text-sm text-slate-500 mt-1">Status: <%= vehicle.status.capitalize %></p>
    </div>
  </div>

  <!-- Right: Actions -->
  <%# Prefer an explicitly active device, otherwise fall back to any linked device %>
  <% device = (vehicle&.active_device || vehicle&.devices&.first) %>

  <div class="flex gap-3 mt-4 sm:mt-0 sm:ml-auto">
    <%= link_to "Documents", vehicle_documents_path(vehicle), class: "btn btn-primary" %>
    <%= link_to "Assign Driver", "/", class: "btn btn-primary" %>
    <%= link_to "Lease/Hire", "/", class: "btn btn-primary" %>
      <% if device.present? %>
        <%= link_to "Show Device", device_path(device), class: "btn btn-primary" %>
      <% else %>
        <%= link_to "Assign GPS Device", new_vehicle_device_path(vehicle), class: "btn btn-primary" %>
      <% end %>

  </div>
</div>


  <!-- Info Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div class="bg-slate-100 dark:bg-slate-700 p-4 rounded-md">
      <p class="text-xs text-slate-500">Model</p>
      <p class="text-base font-medium text-slate-900 dark:text-white"><%= vehicle.vehicle_model&.model %></p>
    </div>
    <div class="bg-slate-100 dark:bg-slate-700 p-4 rounded-md">
      <p class="text-xs text-slate-500">Make</p>
      <p class="text-base font-medium text-slate-900 dark:text-white"><%= vehicle.vehicle_model&.make %></p>
    </div>
    <div class="bg-slate-100 dark:bg-slate-700 p-4 rounded-md">
      <%= link_to fleet_provider_path(vehicle.fleet_provider) do %>
        <p class="text-xs text-slate-500">Fleet Provider</p>
        <p class="text-base font-medium text-slate-900 dark:text-white"><%= vehicle.fleet_provider&.name %></p>
      <% end %>
    </div>
    <div class="bg-slate-100 dark:bg-slate-700 p-4 rounded-md">
      <p class="text-xs text-slate-500">Created At</p>
      <p class="text-base font-medium text-slate-900 dark:text-white"><%= vehicle.created_at.strftime('%B %d, %Y') %></p>
    </div>
  </div>

  <!-- Driver Info -->
  <% if vehicle.driver.present? %>
    <div class="bg-slate-50 dark:bg-slate-700 p-4 rounded shadow-sm">
      <%= link_to driver_path(vehicle.driver) do %>
        <h2 class="text-lg font-semibold mb-2 text-slate-800 dark:text-white">Assigned Driver</h2>
        <p class="text-sm"><strong>Name:</strong> <%= vehicle.driver.full_name %></p>
        <p class="text-sm"><strong>Phone:</strong> <%= vehicle.driver.phone_number %></p>
      <% end %>
    </div>
  <% end %>

  <!-- Dashboard Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 pt-2">
    <!-- Maintenance Card -->
    <%= link_to vehicle_maintenances_path(vehicle), class: "bg-blue-500 dark:bg-blue-900/40 rounded-lg p-4 shadow-sm hover:shadow-md transition block" do %>
      <p class="text-sm text-blue-800 dark:text-blue-300 font-semibold">Maintenances</p>
      <p class="text-2xl font-bold text-blue-900 dark:text-blue-100 mt-1"><%= vehicle.maintenances.count %></p>
      <% total_cost = vehicle.maintenances.sum(:maintenance_cost) %>
      <p class="text-sm text-blue-700 dark:text-blue-300 mt-1">Total Cost: <%= number_to_currency(total_cost, unit: "KES ") %></p>
    <% end %>

    <!-- Incidents Card -->
    <%= link_to vehicle_incidents_path(vehicle), class: "bg-red-500 dark:bg-red-900/40 rounded-lg p-4 shadow-sm hover:shadow-md transition block" do %>
      <p class="text-sm text-red-800 dark:text-red-300 font-semibold">Incidents</p>
      <p class="text-2xl font-bold text-red-900 dark:text-red-100 mt-1"><%= vehicle.incidents.count %></p>
    <% end %>

    <!-- Trips Card -->
    <%= link_to vehicle_trips_path(vehicle), class: "bg-purple-500 dark:bg-purple-900/40 rounded-lg p-4 shadow-sm hover:shadow-md transition block" do %>
      <p class="text-sm text-purple-800 dark:text-purple-300 font-semibold">Trips</p>
      <p class="text-2xl font-bold text-purple-900 dark:text-purple-100 mt-1"><%= vehicle.trips.count %></p>
      <% active_trips = vehicle.trips.where(status: ['scheduled', 'in_progress']).count %>
      <p class="text-sm text-purple-700 dark:text-purple-300 mt-1">Active: <%= active_trips %></p>
    <% end %>

    <!-- Documents Card -->
    <%= link_to vehicle_documents_path(vehicle), class: "bg-green-500 dark:bg-green-900/40 rounded-lg p-4 shadow-sm hover:shadow-md transition block" do %>
      <p class="text-sm text-green-800 dark:text-green-300 font-semibold">Documents</p>
      <p class="text-2xl font-bold text-green-900 dark:text-green-100 mt-1"><%= vehicle.documents.count %></p>
    <% end %>
  </div>

  <!-- Vehicle Activity Log -->
  <div class="bg-slate-50 dark:bg-slate-700 p-4 rounded shadow-sm">
    <h2 class="text-lg font-semibold mb-3 text-slate-800 dark:text-white">Vehicle Activity Log</h2>
    <% if vehicle.activities.any? %>
      <ul class="text-sm text-slate-700 dark:text-slate-300 space-y-1">
        <% vehicle.activities.order(created_at: :desc).limit(10).each do |activity| %>
          <li>
            <span class="text-xs text-slate-500"><%= activity.created_at.strftime('%b %d, %Y %H:%M') %></span>
            — <%= activity.description %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-slate-500 text-sm">No activity recorded yet.</p>
    <% end %>
  </div>

  <!-- LIVE GPS & DEVICE STATUS -->
  <div class="bg-slate-50 dark:bg-slate-700 p-4 rounded shadow-sm space-y-4">

    <div class="flex items-center justify-between">
      <h2 class="text-lg font-semibold text-slate-800 dark:text-white">GPS Tracker</h2>
      <% if defined?(@traccar_device_id) && @traccar_device_id.present? %>
        <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded-full font-medium">Traccar #<%= @traccar_device_id %></span>
      <% end %>
    </div>

    <%# ── Device identity row ─────────────────────────────────────────── %>
    <% active_dev = vehicle.active_device || vehicle.devices.first %>
    <% if active_dev.present? %>
      <div class="flex items-center justify-between flex-wrap gap-2">
        <div class="space-y-1">
          <p class="text-sm">
            <span class="text-slate-500">Terminal ID:</span>
            <span class="font-medium"><%= active_dev.terminal_id.presence || "—" %></span>
          </p>
          <% if active_dev.traccar_id.present? %>
            <p class="text-sm">
              <span class="text-slate-500">Traccar Device ID:</span>
              <span class="font-medium"><%= active_dev.traccar_id %></span>
            </p>
          <% end %>
          <p class="text-sm">
            <span class="text-slate-500">Last JT808 heartbeat:</span>
            <span class="font-medium">
              <%= active_dev.last_heartbeat_at ? active_dev.last_heartbeat_at.strftime("%b %d, %Y %H:%M:%S") : "No heartbeat yet" %>
            </span>
          </p>
        </div>

        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
                    <%= vehicle.device_online? ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800" %>">
          <%= vehicle.device_online? ? "● Online" : "○ Offline" %>
        </span>
      </div>

      <% unless vehicle.active_device %>
        <div class="p-3 bg-yellow-50 border border-yellow-200 rounded text-sm text-yellow-800">
          Device attached but status is not <em>active</em>.
          <%= link_to "View device", device_path(active_dev), class: "underline font-medium" %>
        </div>
      <% end %>

    <% else %>
      <p class="text-sm text-slate-500">
        No device assigned.
        <%= link_to "Assign GPS Device", new_vehicle_device_path(vehicle), class: "underline text-blue-600" %>
      </p>
    <% end %>

    <%# ── Traccar last-known position ─────────────────────────────────── %>
    <% if defined?(@traccar_position) && @traccar_position.present? %>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 p-3 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 rounded-md text-sm">
        <div>
          <p class="text-xs text-slate-500">Latitude</p>
          <p class="font-medium" id="traccar-lat"><%= @traccar_position['latitude'] %></p>
        </div>
        <div>
          <p class="text-xs text-slate-500">Longitude</p>
          <p class="font-medium" id="traccar-lng"><%= @traccar_position['longitude'] %></p>
        </div>
        <div>
          <p class="text-xs text-slate-500">Speed</p>
          <p class="font-medium"><%= @traccar_position['speed'].to_f.round(1) %> km/h</p>
        </div>
        <div>
          <p class="text-xs text-slate-500">Last fix</p>
          <p class="font-medium"><%= @traccar_position['deviceTime'] ? Time.parse(@traccar_position['deviceTime']).strftime("%b %d %H:%M") : "—" %></p>
        </div>
        <% if @traccar_position['address'].present? %>
          <div class="col-span-2 sm:col-span-4">
            <p class="text-xs text-slate-500">Address</p>
            <p class="font-medium"><%= @traccar_position['address'] %></p>
          </div>
        <% end %>
      </div>
    <% elsif active_dev&.traccar_id.present? %>
      <p class="text-sm text-slate-400 italic">Traccar position unavailable right now.</p>
    <% end %>

    <%# ── Link-to-Traccar nudge when device has no traccar_id ─────────── %>
    <% if active_dev.present? && active_dev.traccar_id.blank? %>
      <div class="p-3 bg-slate-100 dark:bg-slate-600 rounded text-sm text-slate-600 dark:text-slate-300">
        This device is not linked to Traccar.
        <%= link_to "Link on device page", device_path(active_dev), class: "underline font-medium" %>
        to enable Traccar tracking.
      </div>
    <% end %>

    <%# ── Map ─────────────────────────────────────────────────────────── %>
    <div id="telemetry-error" class="text-sm text-red-600 hidden"></div>
    <div id="vehicle-map" class="w-full h-80 rounded-md overflow-hidden"></div>

  </div>


</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    // Seed from Traccar last-known position if available, otherwise default
    <% if defined?(@traccar_position) && @traccar_position.present? %>
      const seedLat = <%= @traccar_position['latitude'] %>;
      const seedLng = <%= @traccar_position['longitude'] %>;
    <% else %>
      const seedLat = 0, seedLng = 0;
    <% end %>

    const map = L.map("vehicle-map").setView([seedLat, seedLng], seedLat === 0 ? 3 : 14);
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", { maxZoom: 19 }).addTo(map);

    let marker = null;
    const telemetryErrorEl = document.getElementById("telemetry-error");

    // Place initial marker from Traccar seed
    if (seedLat !== 0 || seedLng !== 0) {
      marker = L.marker([seedLat, seedLng])
        .addTo(map)
        .bindPopup("Last Traccar position")
        .openPopup();
    }

    // Live updates via ActionCable (JT808 protocol)
    const vehicleId = <%= vehicle.id %>;
    const cable = ActionCable.createConsumer();

    cable.subscriptions.create(
      { channel: "VehicleChannel", vehicle_id: vehicleId },
      {
        received(data) {
          const lat = data.lat;
          const lng = data.lng;

          if (typeof lat === "number" && typeof lng === "number") {
            if (!marker) {
              marker = L.marker([lat, lng]).addTo(map);
            } else {
              marker.setLatLng([lat, lng]);
            }
            map.setView([lat, lng], 14);
            marker.bindPopup("Live JT808 position").openPopup();
            telemetryErrorEl.classList.add("hidden");
          } else {
            console.warn("Received telemetry without valid lat/lng", data);
            telemetryErrorEl.textContent = "Received invalid telemetry data.";
            telemetryErrorEl.classList.remove("hidden");
          }
        }
      }
    );
  });
</script>
